APP_ENV=local
AWS_REGION=ap-south-1
LOG_LEVEL=INFO

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=maatitrace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_SECRET=change-this-local-only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

H3_DEFAULT_RESOLUTION=12
H3_MIN_RESOLUTION=7
H3_MAX_RESOLUTION=12
MAX_FARM_H3_CELLS=20000
MAX_POLYGON_VERTICES=500

LOCAL_LAKEHOUSE_PATH=./local_lakehouse
S3_LAKEHOUSE_BUCKET=
ATHENA_DATABASE=
ATHENA_WORKGROUP=
