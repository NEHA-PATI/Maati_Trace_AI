# Recommended additions for .gitignore

# Secrets / local environment
backend/.env
**/.env
**/.env.*
!**/.env.example

# Virtual environments
backend/.venv/
.venv/
venv/
env/
ENV/

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/

# Coverage outputs
.coverage
.coverage.*
htmlcov/
coverage.xml

# Logs
*.log
*.md
*.pdf